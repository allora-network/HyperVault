# HyperEVM RPC endpoints
HYPEREVM_RPC_MAINNET=https://rpc.hyperliquid.xyz/evm
HYPEREVM_RPC_TESTNET=https://rpc.hyperliquid-testnet.xyz/evm

# Block explorer (Hyperliquid uses HyperEVMscan)
HYPEREVM_EXPLORER_URL=https://api.hyperevmscan.io/api
HYPEREVM_EXPLORER_KEY=

# Deployer key (use a hardware wallet via --account in production)
DEPLOYER_PRIVATE_KEY=

# Per-deploy: path to strategy config JSON, relative to repo root
STRATEGY_CONFIG=deployments/configs/example.json

# Registry address (set after one-time DeployRegistry run per chain)
REGISTRY_MAINNET=
REGISTRY_TESTNET=
FACTORY_MAINNET=
FACTORY_TESTNET=
